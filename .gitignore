# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
functions/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/tmp_verify_shots/
/tmp_verify_*.cjs

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# prisma
# prisma/dev.db - COMMITTED for demo/seeded data
prisma/dev.db-journal
prisma/dev.db.backup

# typescript
*.tsbuildinfo
next-env.d.ts

# SST
.sst/
.open-next/

# Old deployment artifacts (no longer used - now using SST)
lambdas/
scripts/migrate-data.ts

# superpowers
.superpowers/

# Public-domain scripture PDFs downloaded via curl for citation work.
# Each file is independently downloadable from archive.org / sanskritweb.net —
# excluding from the repo to avoid bloating git history.
/scriptures/

# Extracted text from scripture PDFs — regenerable via pdftotext.
/scriptures/extracted/

# Source posters — raw JPEGs from WhatsApp drop. The curated subset lives
# in public/posters/*.webp; originals stay local-only.
/Posters/
/Posters.zip
