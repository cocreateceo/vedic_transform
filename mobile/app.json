{
  "expo": {
    "name": "10X Vedic",
    "slug": "vedic-transform",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vedictransform",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFEF5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vedictransform.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF9933"
      },
      "package": "com.vedictransform.app",
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5105fa20-0390-45c6-b2fd-a2ccb554f450"
      }
    },
    "owner": "vinothkumarcocreate"
  }
}
