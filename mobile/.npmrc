# expo-router transitively pulls in react-dom@19.2.6 which peer-requires
# react@^19.2.6, but Expo SDK 54 ships with react@19.1.0. Local `npm install`
# tolerates this; cloud `npm ci` (used by EAS Build) does not without
# legacy-peer-deps. This matches what most Expo + RN projects do.
legacy-peer-deps=true
